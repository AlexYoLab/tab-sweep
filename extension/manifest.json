{
  "manifest_version": 3,
  "name": "TabSweep",
  "version": "1.0.0",
  "description": "A beautiful Chrome extension to manage and clean your tabs",
  "permissions": [
    "tabs",
    "activeTab",
    "storage"
  ],
  "action": {},
  "chrome_url_overrides": {
    "newtab": "dist/index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
